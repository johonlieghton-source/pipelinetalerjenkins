pipeline {
    agent any

    environment {
        IMAGE_NAME = 'mi-app-web'
        CONTAINER_NAME = 'mi-contenedor-web'
        // ---> CAMBIA ESTAS VARIABLES POR LOS DATOS DE TU VM <---
        VM_IP = '192.168.1.122' 
        VM_USER = 'jenkins'
        SSH_CREDS = 'ssh-vm-vmware' // El ID que pusiste en el paso 3
    }

    stages {
        stage('Descargar código') {
            steps {
                git branch: 'main', url: 'https://github.com/johonlieghton-source/pipelinetalerjenkins.git’
            }
        }
        
        stage('Construir Imagen Docker') {
            steps {
                script {
                    docker.build("${mi_docker_de_prueba}:latest")
                }
            }
        }

        stage('Empaquetar Imagen') {
            steps {
                echo 'Convirtiendo imagen a archivo .tar para enviarla...'
                sh "docker save ${mi_docker_de_prueba}:latest -o ${mi_docker_de_prueba}.tar"
            }
        }
        
        stage('Enviar a VM de VMware') {
            steps {
                echo 'Enviando archivo por SSH a la VM...'
                sshagent(credentials: ["${jenkins@192.168.1.122}"]) {
                    // Usamos scp para enviar el archivo .tar al directorio /tmp de la VM
                    sh "scp -o StrictHostKeyChecking=no ${mi_docker_de_prueba}.tar ${jenkins}@${192.168.1.122}:/tmp/${mi_docker_de_prueba}.tar"
                }
            }
        }

        stage('Desplegar en VM de VMware') {
            steps {
                echo 'Levantando el contenedor en la VM remota...'
                sshagent(credentials: ["${jenkins@192,168,1,122}"]) {
                    // Usamos ssh para ejecutar comandos directamente en la VM
                    sh """
                    ssh -o StrictHostKeyChecking=no ${jenkins}@${192.168.1.122} << 'EOF'
                        echo "Deteniendo contenedor anterior..."
                        docker stop ${mi_contenedor_de_prueba} || true
                        docker rm ${mi_contenedor_de_prueba} || true
                        
                        echo "Cargando nueva imagen..."
                        docker load -i /tmp/${mi_docker_de_prueba}.tar
                        
                        echo "Levantando nuevo contenedor..."
                        docker run -d -p 80:80 --name ${mi_contenedor_de_prueba} ${mi_docker_de_prueba}:latest
                        
                        echo "Limpiando archivo temporal..."
                        rm /tmp/${mi_docker_de_prueba}.tar
                    EOF
                    """
                }
            }
        }
    }

    post {
        always {
            echo 'Limpiando archivos temporales en Jenkins...'
            sh "rm -f ${mi_docker_de_prueba}.tar"
        }
        success {
            echo "¡Despliegue exitoso en la VM ${192,168,1,122}!"
        }
        failure {
            echo 'El despliegue falló. Revisa los logs.'
        }
    }
}
